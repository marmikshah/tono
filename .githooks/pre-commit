#!/bin/sh
# Pre-commit gate: the non-mutating lint checks (format + clippy), so a commit
# can't land unformatted or with warnings. Enable once per clone with:
#   git config core.hooksPath .githooks   (or: make hooks)
set -e
echo "pre-commit: fmt --check + clippy..."
cargo fmt --all -- --check
cargo clippy --all-targets -- -D warnings
echo "pre-commit: clean."
