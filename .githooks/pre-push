#!/bin/sh
# Pre-push gate: refuse a direct push to master, then run the exact CI steps
# locally so a push can never burn a failing Actions run. The gate lives in one
# place — the Makefile targets. Enable once per clone with:
#   git config core.hooksPath .githooks
# Emergency bypass: git push --no-verify.
set -e
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    if [ "$remote_ref" = "refs/heads/master" ]; then
        echo "pre-push: refusing direct push to master — open a PR." >&2
        exit 1
    fi
done
exec make verify
