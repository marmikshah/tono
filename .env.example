# sonarium configuration — all optional, none secret.
# It is a deterministic, offline tool: no API keys, no network credentials.
# Copy to .env only if you want to override defaults; nothing here is required.

# Where rendered audio / exports land (default: ~/.sonarium/sounds).
# Point it at your game's assets folder to drop renders straight in.
# SONARIUM_WORKDIR=./sounds

# HTTP bind address when running the streamable-HTTP MCP server.
# SONARIUM_BIND=127.0.0.1:8787

# Force a transport: "http" runs the HTTP server (default is stdio).
# SONARIUM_TRANSPORT=http

# Log filter (logs go to stderr).
# RUST_LOG=info
